---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import { LINKS, PRICING } from '../config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="pricing" class="section">
  <div class="container">
    <div class="pr-layout">
      <header class="pr-head">
        <p class="eyebrow">{t.nav.pricing}</p>
        <h2 class="section-title">{t.pricing.heading}</h2>
        <p class="section-lead">{t.pricing.lead}</p>
      </header>

      <div class="pr-card card">
        <div class="pr-plan-row">
          <div>
            <p class="pr-plan">{t.pricing.planName}</p>
            <p class="pr-tbd">{t.pricing.priceTbd}</p>
          </div>
          <div class="pr-price">
            <span class="pr-amount">{PRICING.amount}</span>
            <span class="pr-per">/ {t.pricing.per}</span>
          </div>
        </div>

        <ul class="pr-points">
          {
            t.pricing.points.map((p) => (
              <li>
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 13 4 4 10-10" /></svg>
                {p}
              </li>
            ))
          }
        </ul>

        <a href={LINKS.checkout} class="btn btn-primary pr-cta">{t.pricing.cta}</a>
        <p class="pr-fine">{t.pricing.fine}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .pr-layout {
    display: grid;
    grid-template-columns: 0.86fr 1.14fr;
    gap: clamp(28px, 6vw, 72px);
    align-items: start;
  }
  .pr-head {
    position: sticky;
    top: 88px;
    max-width: 500px;
  }
  .pr-card {
    position: relative;
    padding: clamp(24px, 4vw, 38px);
    text-align: left;
    overflow: hidden;
  }
  .pr-plan-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 22px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--sep);
  }
  .pr-plan {
    font-family: var(--font-round);
    font-weight: 700;
    color: var(--text-1);
    font-size: 1rem;
  }
  .pr-price {
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    gap: 8px;
    text-align: right;
  }
  .pr-amount {
    font-family: var(--font-round);
    font-weight: 800;
    font-size: clamp(2.6rem, 5vw, 3.4rem);
    letter-spacing: 0;
  }
  .pr-per {
    color: var(--text-2);
    font-weight: 600;
  }
  .pr-tbd {
    color: var(--text-3);
    font-size: 0.82rem;
    margin-top: 4px;
  }
  .pr-points {
    display: flex;
    flex-direction: column;
    gap: 11px;
    margin: 26px 0;
    text-align: left;
  }
  .pr-points li {
    display: flex;
    align-items: center;
    gap: 11px;
    font-size: 0.96rem;
    color: var(--text-1);
  }
  .pr-points svg {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    fill: none;
    stroke: var(--green);
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .pr-cta {
    width: 100%;
  }
  .pr-fine {
    margin-top: 14px;
    font-size: 0.8rem;
    color: var(--text-3);
  }
  @media (max-width: 820px) {
    .pr-layout {
      grid-template-columns: 1fr;
    }
    .pr-head {
      position: static;
    }
  }
  @media (max-width: 560px) {
    .pr-plan-row {
      flex-direction: column;
    }
    .pr-price {
      text-align: left;
      justify-content: flex-start;
    }
  }
</style>
