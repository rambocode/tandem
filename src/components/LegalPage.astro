---
import Base from '../layouts/Base.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { localizePath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import type { PrivacyDoc } from '../i18n/legal';

interface Props {
  lang: Lang;
  /** 站内路径，用于 canonical / hreflang，如 '/privacy/'。 */
  path: string;
  doc: PrivacyDoc;
}
const { lang, path, doc } = Astro.props;
const home = localizePath('/', lang);
---

<Base lang={lang} path={path} title={`${doc.title} — Tandem`} description={doc.metaDescription}>
  <Header lang={lang} />
  <main class="legal">
    <div class="container legal-inner">
      <h1>{doc.title}</h1>
      <p class="legal-updated">{doc.updatedLabel}: {doc.updated}</p>

      {doc.intro.map((para) => <p class="legal-lead">{para}</p>)}

      {
        doc.sections.map((s) => (
          <section class="legal-section">
            <h2>{s.h}</h2>
            {s.p?.map((para) => <p>{para}</p>)}
            {s.list && (
              <ul>
                {s.list.map((li) => (
                  <li>{li}</li>
                ))}
              </ul>
            )}
          </section>
        ))
      }

      <p class="legal-back"><a href={home}>{doc.backHome}</a></p>
    </div>
  </main>
  <Footer lang={lang} />
</Base>

<style>
  .legal {
    padding-block: 56px 72px;
  }
  .legal-inner {
    max-width: 760px;
  }
  .legal h1 {
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-1);
  }
  .legal-updated {
    margin-top: 8px;
    color: var(--text-3);
    font-size: 0.88rem;
  }
  .legal-lead {
    margin-top: 18px;
    color: var(--text-2);
    font-size: 1.02rem;
    line-height: 1.7;
  }
  .legal-section {
    margin-top: 40px;
  }
  .legal h2 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-1);
    margin-bottom: 12px;
  }
  .legal-section p {
    color: var(--text-2);
    line-height: 1.75;
    margin-top: 10px;
  }
  .legal-section ul {
    margin-top: 12px;
    padding-left: 1.2em;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .legal-section li {
    color: var(--text-2);
    line-height: 1.7;
    list-style: disc;
  }
  .legal-back {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--sep);
    font-weight: 600;
  }
  .legal-back a {
    color: var(--brand-1);
  }
  .legal-back a:hover {
    text-decoration: underline;
  }
</style>
