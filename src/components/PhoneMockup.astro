---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="phone" role="img" aria-label="Tandem on iPhone">
  <div class="island"></div>
  <div class="screen">
    <div class="recv-head">
      <span class="recv-live"></span>
      {t.mockup.phoneReceived}
    </div>
    <div class="recv-card">
      <p class="recv-body">{t.mockup.clipText}</p>
      <button class="paste" type="button" tabindex="-1">⌘⇧V</button>
    </div>
  </div>
</div>

<style>
  .phone {
    position: relative;
    width: clamp(188px, 17vw, 238px);
    aspect-ratio: 384 / 832;
    background: #101014;
    border: 1px solid var(--sep-strong);
    border-radius: 50px;
    padding: 12px;
    box-shadow: var(--shadow-pop);
  }
  .island {
    position: absolute;
    top: 11px;
    left: 50%;
    transform: translateX(-50%);
    width: 30%;
    height: 26px;
    background: #000;
    border-radius: 999px;
    z-index: 2;
  }
  .screen {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.6)),
      var(--surface-2);
    border-radius: 42px;
    padding: 48px 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: hidden;
  }
  .recv-head {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--text-2);
  }
  .recv-live {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
  }
  .recv-card {
    background: var(--surface);
    border: 1px solid var(--sep);
    border-radius: 12px;
    padding: 14px;
    animation: floatUp 0.4s ease both;
    animation-delay: 0.5s;
  }
  .recv-body {
    font-size: 0.9rem;
    color: var(--text-1);
    margin-bottom: 12px;
  }
  .paste {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: #fff;
    background: var(--text-1);
    border: none;
    border-radius: 9px;
    padding: 7px 12px;
    cursor: default;
  }
</style>
