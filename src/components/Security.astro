---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const icons = ['lan', 'shield', 'cloud'];
---

<section class="section sec-section">
  <div class="container">
    <header class="sec-head">
      <h2 class="section-title">{t.security.heading}</h2>
      <p class="section-lead">{t.security.lead}</p>
    </header>

    <ul class="sec-grid">
      {
        t.security.points.map((p, i) => (
          <li class="sec-item">
            <span class="sec-ico" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                {icons[i] === 'lan' && (
                  <>
                    <rect x="3" y="4" width="18" height="11" rx="2" />
                    <path d="M8 20h8M12 15v5" />
                  </>
                )}
                {icons[i] === 'shield' && (
                  <>
                    <path d="M12 3 5 6v5c0 4 3 7 7 9 4-2 7-5 7-9V6z" />
                    <path d="m9 12 2 2 4-4" />
                  </>
                )}
                {icons[i] === 'cloud' && (
                  <>
                    <path d="M7 18h9a4 4 0 0 0 .9-7.9A5 5 0 0 0 8 8" />
                    <path d="m4 4 16 16" />
                  </>
                )}
              </svg>
            </span>
            <h3 class="sec-title">{p.title}</h3>
            <p class="sec-desc">{p.desc}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .sec-section {
    background: var(--text-1);
    color: var(--surface);
    border-block: 1px solid var(--sep);
  }
  .sec-head {
    max-width: 720px;
    margin-bottom: clamp(28px, 4vw, 48px);
  }
  .sec-section .section-lead {
    color: rgba(255, 255, 255, 0.64);
  }
  .sec-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(18px, 3vw, 36px);
  }
  .sec-ico {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    margin-bottom: 16px;
  }
  .sec-ico svg {
    width: 26px;
    height: 26px;
    fill: none;
    stroke: var(--green);
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .sec-title {
    font-size: 1.18rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .sec-desc {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.96rem;
  }

  @media (max-width: 760px) {
    .sec-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
