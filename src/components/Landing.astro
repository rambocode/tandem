---
import Base from '../layouts/Base.astro';
import Header from './Header.astro';
import Hero from './Hero.astro';
import Pills from './Pills.astro';
import Features from './Features.astro';
import ProTable from './ProTable.astro';
import Pricing from './Pricing.astro';
import Security from './Security.astro';
import FAQ from './FAQ.astro';
import Footer from './Footer.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<Base lang={lang}>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Pills lang={lang} />
    <Features lang={lang} />
    <ProTable lang={lang} />
    <Pricing lang={lang} />
    <Security lang={lang} />
    <FAQ lang={lang} />
  </main>
  <Footer lang={lang} />
</Base>
